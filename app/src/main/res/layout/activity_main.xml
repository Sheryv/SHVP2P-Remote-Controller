<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:orientation="horizontal"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".view.MainActivity">

    <TextView
        android:id="@+id/text_last_packets"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="8dp"
        android:text="last status"
        android:textAppearance="@style/TextAppearance.AppCompat.Small"
        android:typeface="monospace"
        app:layout_constraintEnd_toStartOf="@+id/text_state"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.yoimerdr.android.virtualjoystick.views.JoystickView
        android:id="@+id/left_joystick"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginStart="24dp"
        android:layout_marginBottom="16dp"
        app:controlDrawer_accentColor="#FFFFFF"
        app:controlDrawer_primaryColor="#FF0000"
        app:controlType="circe_arc"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <com.yoimerdr.android.virtualjoystick.views.JoystickView
        android:id="@+id/right_joystick"
        android:layout_width="240dp"
        android:layout_height="240dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="16dp"
        app:controlDrawer_accentColor="#FFFFFF"
        app:controlDrawer_primaryColor="#FF0000"
        app:controlType="circe_arc"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <FrameLayout
        android:id="@+id/frameLayout"
        android:layout_width="48dp"
        android:layout_height="200dp"
        android:layout_gravity="center"
        android:layout_marginStart="48dp"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@+id/left_joystick"
        app:layout_constraintStart_toEndOf="@+id/left_joystick"
        >

        <com.google.android.material.slider.Slider
            style="@style/Widget.Material3.Slider"
            android:id="@+id/slider_throttle"
            android:layout_width="200dp"
            android:layout_height="match_parent"
            android:layout_gravity="center"
            android:contentDescription="throttle"
            android:rotation="270"
            android:stepSize="1"
            app:tickVisible="false"
            android:value="0"
            android:valueFrom="0"
            android:valueTo="100" />

    </FrameLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/constraintLayout"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:layout_marginStart="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/right_joystick"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toEndOf="@+id/frameLayout"
        app:layout_constraintTop_toTopOf="@+id/frameLayout"
        app:layout_constraintVertical_bias="0.0">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/button_bit0"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Bit 0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_bit1"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Bit 1"
            app:layout_constraintEnd_toEndOf="@+id/button_bit0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/button_bit0" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/switch_bit2"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:text="Bit 2"
            app:layout_constraintEnd_toEndOf="@+id/button_bit0"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/switch_bit1" />

        <TextView
            android:id="@+id/text_throttle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Thottle: 0%"
            android:typeface="monospace"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/text_state"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="8dp"
        android:text="-"
        app:layout_constraintBottom_toBottomOf="@+id/button_connect"
        app:layout_constraintEnd_toStartOf="@+id/button_connect"
        app:layout_constraintTop_toTopOf="parent" />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/settings_button"
        style="@style/Widget.Material3.Button.IconButton.Filled.Tonal"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginEnd="5dp"
        android:contentDescription="settings"
        app:icon="@drawable/baseline_settings_24"
        app:iconGravity="textStart"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />


    <TextView
        android:id="@+id/text_left_joy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:typeface="monospace"
        android:text="Yaw"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        app:layout_constraintBottom_toTopOf="@+id/frameLayout"
        app:layout_constraintStart_toEndOf="@+id/left_joystick"
         />

    <TextView
        android:id="@+id/text_right_joy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="3dp"
        android:text="Roll"
        android:textAppearance="@style/TextAppearance.AppCompat.Medium"
        android:typeface="monospace"
        app:layout_constraintBottom_toTopOf="@+id/constraintLayout"
        app:layout_constraintStart_toStartOf="@+id/constraintLayout" />

<!--        style="@style/Widget.MaterialComponents.Button"-->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/button_connect"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:layout_marginEnd="24dp"
        android:text="Start server"
        app:layout_constraintEnd_toStartOf="@+id/settings_button"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>