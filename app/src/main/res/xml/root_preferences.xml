<?xml version="1.0" encoding="utf-8"?>
<androidx.preference.PreferenceScreen xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_height="match_parent"
    app:iconSpaceReserved="false"
    android:layout_width="match_parent">

    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="Global" />

    <androidx.preference.Preference
        app:iconSpaceReserved="false"
        app:key="address"
        app:summary="Tap to copy"
        app:title="Address: " />

    <androidx.preference.EditTextPreference
        app:key="port"
        app:useSimpleSummaryProvider="true"
        app:iconSpaceReserved="false"

        app:defaultValue="9789"
        app:title="Server port number" />


    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="Throttle adjustments" />
    <androidx.preference.EditTextPreference
        app:key="throttle_min"
        app:iconSpaceReserved="false"
        app:defaultValue="0"
        app:useSimpleSummaryProvider="true"
        app:title="Throttle min value" />
    <androidx.preference.EditTextPreference
        app:key="throttle_max"
        app:iconSpaceReserved="false"
        app:defaultValue="100"
        app:useSimpleSummaryProvider="true"
        app:title="Throttle max value" />


    <androidx.preference.PreferenceCategory
        app:iconSpaceReserved="false"
        app:title="Joystick adjustments" />

    <androidx.preference.SwitchPreference
        app:iconSpaceReserved="false"
        app:defaultValue="false"
        app:key="pitch_axis_on_left"
        app:title="Move pitch axis to left joystick" />


</androidx.preference.PreferenceScreen>
